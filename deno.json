{
  "unstable": ["cron", "kv"],
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check",
    "start": "deno run -A --env --watch=static/,routes/ dev.ts",
    "build": "deno run -A --env dev.ts build",
    "preview": "deno serve -A _fresh/server.js",
    "build_preview": "deno task build && deno task preview",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "fmt": {
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "nodeModulesDir": "auto",
  "imports": {
    "~/": "./",
    "fresh": "jsr:@fresh/core@^2.1.4",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.4.0",
    "tailwindcss": "npm:tailwindcss@4.1.16",
    "tailwindcss/": "npm:/tailwindcss@4.1.16/",
    "tailwindcss/plugin": "npm:/tailwindcss@4.1.16/plugin.js",
    "@fresh/plugin-tailwind": "jsr:@fresh/plugin-tailwind@^1.0.0",
    "tabler_icons/": "https://deno.land/x/tabler_icons_tsx@0.0.6/tsx/",
    "@deno/gfm": "jsr:@deno/gfm@^0.11.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}

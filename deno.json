{
  "unstable": ["cron", "kv"],
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A --env _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "fmt": {
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "nodeModulesDir": "auto",
  "imports": {
    "~/": "./",
    "fresh": "jsr:@fresh/core@^2.1.4",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.4.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.7",
    "vite": "npm:vite@^7.2.2",
    "tailwindcss": "npm:/tailwindcss@4.1.17",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.17",
    "tabler_icons/": "https://deno.land/x/tabler_icons_tsx@0.0.6/tsx/",
    "@lambdaurora/libmd": "jsr:@lambdaurora/libmd@^2.3.1",
    "@deno/gfm/style": "https://raw.githubusercontent.com/denoland/deno-gfm/eb1841c72f480eb126b87a62e2ca27e9addd53aa/style.ts"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
